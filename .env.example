# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Platform admin panel (/admin) — comma-separated emails allowed cross-tenant
# access. Server-only (NEVER prefix NEXT_PUBLIC). Empty = nobody is an admin.
ADMIN_EMAILS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server only — never imported in client components

# Anthropic (AI PDF import)
ANTHROPIC_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Paddle (active billing provider)
NEXT_PUBLIC_PADDLE_ENVIRONMENT=sandbox   # sandbox | production
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=         # Developer tools → Authentication → client-side token
NEXT_PUBLIC_PADDLE_PRICE_ID=             # the $39/mo price (pri_...)
PADDLE_API_KEY=                          # server-side API key (portal sessions)
PADDLE_WEBHOOK_SECRET=                   # notification destination secret (pdl_ntfset_...)

# Stripe — DORMANT (Paddle is active; kept for a possible future switch)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=                  # the $39/mo price

# Cloudflare Turnstile (public signing endpoint)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Dev-only: uncomment to allow `npm run seed:demo` (demo org + fake signatures).
# NEVER set this in production.
# ALLOW_DEV_SEED=true

# Ads / analytics plumbing (optional — snippets render only when set)
NEXT_PUBLIC_GA_MEASUREMENT_ID=          # Google Analytics 4, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=              # e.g. AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_SIGNUP_LABEL=    # conversion label for signup completion
NEXT_PUBLIC_CLARITY_PROJECT_ID=
